            "url": {
              "raw": "{{base_url}}/admin/users?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "limit",    "value": "20" },
                { "key": "role",     "value": "", "disabled": true },
                { "key": "status",   "value": "", "disabled": true },
