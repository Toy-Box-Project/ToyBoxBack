          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const r = pm.response.json();",
                  "  pm.collectionVariables.set('chat_id', r.id_conversations);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Chats",
