          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/chats/{{chat_id}}/messages", "host": ["{{base_url}}"], "path": ["chats", "{{chat_id}}", "messages"] },
            "body": {
